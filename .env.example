# Spotify OAuth app credentials (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# One-time bootstrap: `python -m src.main bootstrap-spotify` prints this.
SPOTIFY_REFRESH_TOKEN=

# Source playlist on Spotify (the account owning SPOTIFY_REFRESH_TOKEN must own it).
SPOTIFY_PLAYLIST_NAME=测试同步

# Target playlist on QQ Music. Auto-created if missing.
QQ_PLAYLIST_NAME=测试同步

# JSON blob produced by `python -m src.main bootstrap-qq` (single line).
QQ_CREDENTIAL_JSON=

# Fine-grained PAT with `secrets:write` on this repo. Optional — only needed
# so GitHub Actions can rotate QQ_CREDENTIAL_JSON after a musickey refresh.
GH_PAT_SECRETS_WRITE=

# Safety net for mirror mode: abort if deletes exceed this fraction of the
# current QQ playlist (default 0.2 = 20%).
MIRROR_DELETE_THRESHOLD=0.2

# MusicBrainz User-Agent sent on alias lookups. MB policy requires a contact;
# default embeds the author's email — override for your own fork.
# MUSICBRAINZ_USER_AGENT=spotify-qq-sync/0.2 (CarfagnoArcino@gmail.com)

# Optional path overrides (defaults shown).
# DB_PATH=data/sync.db
# LOG_PATH=data/sync.log
# UNMATCHED_PATH=data/unmatched.txt
